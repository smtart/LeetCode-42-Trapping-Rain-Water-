<script>
// ========== RAIN ANIMATION ==========
function createRain() {
  const bg = document.getElementById('rainBg');
  for (let i = 0; i < 60; i++) {
    const drop = document.createElement('div');
    drop.className = 'raindrop';
    drop.style.left = Math.random() * 100 + '%';
    drop.style.height = (15 + Math.random() * 25) + 'px';
    drop.style.animationDuration = (0.6 + Math.random() * 0.8) + 's';
    drop.style.animationDelay = (Math.random() * 2) + 's';
    bg.appendChild(drop);
  }
}
createRain();

// ========== VISUALIZATION ==========
let height = [0,1,0,2,1,0,1,3,2,1,2,1];
let currentStep = -1;
let autoInterval = null;
let waterAmounts = [];
let leftMax = [];
let rightMax = [];

function computeArrays() {
  const n = height.length;
  leftMax = Array(n).fill(0);
  rightMax = Array(n).fill(0);
  waterAmounts = Array(n).fill(0);
  leftMax[0] = height[0];
  for (let i = 1; i < n; i++) leftMax[i] = Math.max(leftMax[i-1], height[i]);
  rightMax[n-1] = height[n-1];
  for (let i = n-2; i >= 0; i--) rightMax[i] = Math.max(rightMax[i+1], height[i]);
  let total = 0;
  for (let i = 0; i < n; i++) {
    waterAmounts[i] = Math.max(0, Math.min(leftMax[i], rightMax[i]) - height[i]);
    total += waterAmounts[i];
  }
  return total;
}

function buildChart(showWater = []) {
  const chart = document.getElementById('bar-chart');
  chart.innerHTML = '';
  const maxH = Math.max(...height, 1);
  const totalPx = 200;

  height.forEach((h, i) => {
    const col = document.createElement('div');
    col.className = 'bar-col';
    col.id = 'col-' + i;

    const w = showWater[i] || 0;
    const stonePx = Math.round((h / maxH) * totalPx);
    const waterPx = Math.round((w / maxH) * totalPx);

    if (waterPx > 0) {
      const waterEl = document.createElement('div');
      waterEl.className = 'water-cell';
      waterEl.id = 'water-' + i;
      waterEl.style.height = waterPx + 'px';
      col.appendChild(waterEl);
    }

    if (h > 0) {
      const stoneEl = document.createElement('div');
      stoneEl.className = 'stone-cell';
      stoneEl.id = 'stone-' + i;
      stoneEl.style.height = stonePx + 'px';
      col.appendChild(stoneEl);
    } else {
      // Empty slot placeholder
      const emptyEl = document.createElement('div');
      emptyEl.style.height = '2px';
      emptyEl.style.width = '100%';
      emptyEl.style.background = 'rgba(255,255,255,0.1)';
      col.appendChild(emptyEl);
    }

    const tooltip = document.createElement('div');
    tooltip.className = 'bar-tooltip';
    tooltip.textContent = `i=${i} h=${h}`;
    col.appendChild(tooltip);

    const idx = document.createElement('div');
    idx.className = 'bar-idx';
    idx.textContent = i;
    col.appendChild(idx);

    chart.appendChild(col);
  });
}

function getStepMessage(i) {
  const lm = leftMax[i], rm = rightMax[i], wl = Math.min(lm, rm), w = waterAmounts[i];
  const h = height[i];
  return `<strong>Position ${i}</strong> — Height = <span class="highlight-a">${h}</span><br>
    🟢 Tallest left wall: <span class="highlight-g">${lm}</span> &nbsp;|&nbsp; 🔴 Tallest right wall: <span class="highlight-r">${rm}</span><br>
    💧 Water level = min(${lm}, ${rm}) = <span class="highlight">${wl}</span> — ground height ${h} = <span class="highlight">${w}</span> units`;
}

function stepForward() {
  stopAuto();
  if (currentStep < height.length - 1) {
    currentStep++;
    renderStep(currentStep);
  } else {
    document.getElementById('stepInfo').innerHTML = `🎉 <strong>Done!</strong> Total water trapped = <span class="highlight-a">${computeArrays()}</span> units. The algorithm checked every bar exactly once!`;
  }
}

function renderStep(idx) {
  // Show water up to current step
  const showWater = height.map((_, i) => i <= idx ? waterAmounts[i] : 0);
  buildChart(showWater);

  // Highlight current
  const stone = document.getElementById('stone-' + idx);
  if (stone) stone.classList.add('highlighted');

  // Stats
  document.getElementById('statCurrent').textContent = idx;
  let collected = waterAmounts.slice(0, idx + 1).reduce((a, b) => a + b, 0);
  document.getElementById('statWater').textContent = collected;

  // Step info
  document.getElementById('stepInfo').innerHTML = getStepMessage(idx);

  // Progress
  const pct = ((idx + 1) / height.length) * 100;
  document.getElementById('progressFill').style.width = pct + '%';
}

function showAllWater() {
  stopAuto();
  currentStep = height.length - 1;
  buildChart(waterAmounts);
  const total = computeArrays();
  document.getElementById('statCurrent').textContent = '✓';
  document.getElementById('statWater').textContent = total;
  document.getElementById('stepInfo').innerHTML = `💧 All <span class="highlight-a">${total}</span> units of water shown! Every "valley" between taller bars fills up. Hover over bars to see their index.`;
  document.getElementById('progressFill').style.width = '100%';
}

function resetViz() {
  stopAuto();
  currentStep = -1;
  computeArrays();
  buildChart([]);
  document.getElementById('stepInfo').innerHTML = '👆 Press <strong>Step Forward</strong> to watch the algorithm process each bar one by one, or hit <strong>Auto Play</strong> to watch it solve itself!';
  document.getElementById('statCurrent').textContent = '—';
  document.getElementById('statWater').textContent = '0';
  document.getElementById('progressFill').style.width = '0%';
}

function autoPlay() {
  if (autoInterval) { stopAuto(); return; }
  document.getElementById('autoBtn').textContent = '⏸ Pause';
  autoInterval = setInterval(() => {
    if (currentStep < height.length - 1) {
      currentStep++;
      renderStep(currentStep);
    } else {
      stopAuto();
      document.getElementById('stepInfo').innerHTML = `🎉 <strong>Done!</strong> Total water trapped = <span class="highlight-a">${computeArrays()}</span> units!`;
    }
  }, 700);
}

function stopAuto() {
  if (autoInterval) { clearInterval(autoInterval); autoInterval = null; }
  document.getElementById('autoBtn').textContent = '⚡ Auto Play';
}

function loadCustom() {
  const raw = document.getElementById('customInput').value;
  try {
    const arr = raw.split(',').map(x => parseInt(x.trim())).filter(x => !isNaN(x) && x >= 0);
    if (arr.length < 2) throw new Error();
    height = arr;
    const total = computeArrays();
    document.getElementById('statTotal').textContent = total;
    resetViz();
  } catch(e) {
    document.getElementById('stepInfo').innerHTML = '<span style="color:var(--red)">⚠️ Please enter valid non-negative numbers separated by commas.</span>';
  }
}

// ========== TABS ==========
function switchTab(el, id) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById(id).classList.add('active');
}

// ========== INIT ==========
computeArrays();
buildChart([]);
document.getElementById('statTotal').textContent = computeArrays();
</script>
</body>
